generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SALES
}

enum LeadStatus {
  NEW
  CONTACT_PENDING
  QUALIFIED
  HIGH_INTENT
  CONVERTED
  REVIEWING
  DECLINED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NotificationChannel {
  EMAIL
  LINE
  TELEGRAM
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String
  role         Role
  leads        Lead[]       @relation("AssignedSales")
  followUps    FollowUpLog[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Lead {
  id                     String              @id @default(cuid())
  fullName               String
  phone                  String
  lineId                 String
  fundingNeed            Int
  fundingUse             String
  jobType                String
  monthlyIncome          Int
  hasPayroll             Boolean
  hasLaborInsurance      Boolean
  hasTaxRecords          Boolean
  hasCreditCard          Boolean
  hasRevolving           Boolean
  hasOtherLoans          Boolean
  monthlyDebtPayment     Int
  recentLatePayment      Boolean
  hasNegotiationOrBankruptcy Boolean
  hasCar                 Boolean
  hasHouse               Boolean
  hasGuarantor           Boolean
  status                 LeadStatus          @default(NEW)
  assignedSalesId        String?
  assignedSales          User?               @relation("AssignedSales", fields: [assignedSalesId], references: [id])
  recommendation         Recommendation?
  answers                LeadAnswer[]
  followUps              FollowUpLog[]
  notifications          NotificationLog[]
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  @@index([status])
  @@index([assignedSalesId])
  @@index([createdAt])
  @@index([phone])
}

model LeadAnswer {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  key       String
  value     Json
  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([key])
}

model Recommendation {
  id                  String      @id @default(cuid())
  leadId              String      @unique
  lead                Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  primaryRecommendation   String
  secondaryRecommendation  String?
  riskLevel           RiskLevel
  score               Int
  reasons             Json
  requiredDocuments   Json
  needManualReview    Boolean
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

model FollowUpLog {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  note      String
  status    LeadStatus
  createdBy String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([createdAt])
}

model NotificationLog {
  id        String              @id @default(cuid())
  leadId    String
  lead      Lead                @relation(fields: [leadId], references: [id], onDelete: Cascade)
  channel   NotificationChannel
  target    String
  status    String
  message   String
  createdAt DateTime            @default(now())

  @@index([leadId])
  @@index([channel])
}
